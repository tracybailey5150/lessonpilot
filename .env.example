# LessonPilot — Environment Variables
# Copy to .env.local and fill in real values
# See ENVIRONMENT.md for details on each variable

# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=https://hhqqwnqplvpddrxduvif.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# OpenAI (required for AI features)
OPENAI_API_KEY=sk-...

# Stripe (optional locally, required in production)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Resend Email (optional locally)
RESEND_API_KEY=re_...
